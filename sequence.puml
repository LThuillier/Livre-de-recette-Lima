@startuml
title Diagramme de Séquence - Ajout d'une recette

skinparam maxMessageSize 150
skinparam participant {
    BackgroundColor LightCyan
    BorderColor DarkCyan
}
skinparam database {
    BackgroundColor LightYellow
    BorderColor DarkGoldenRod
}
skinparam actor {
    BackgroundColor LightBlue
    BorderColor DarkBlue
}

actor "Utilisateur" as User
participant "Vue Flutter\n(AjoutRecetteScreen)" as View
participant "Service Réseau\n(SupabaseService)" as Service
database "Base de données\n(Supabase)" as DB

User -> View : Remplit le formulaire (titre, image, etc.)\net clique sur "Enregistrer"
activate View

View -> Service : ajouterRecette(nouvelleRecette)
activate Service

Service -> Service : Validation des données saisies

Service -> DB : Requête d'insertion (SDK Supabase)
activate DB

DB --> Service : Réponse 201 Created (Succès)
deactivate DB

Service --> View : Retourne un statut de succès
deactivate Service

View --> User : Affiche un message de confirmation\net redirige vers l'accueil
deactivate View
@enduml