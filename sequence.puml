@startuml
actor "Administrateur" as Admin
participant "Vue\n(create.blade.php)" as Vue
participant "IngredientController" as Controller
participant "Validation\n(Request)" as Validator
database "Base de données\n(MySQL)" as BDD

Admin -> Vue : Accède au formulaire d'ajout
activate Vue
Vue --> Admin : Affiche le formulaire
deactivate Vue

Admin -> Vue : Saisit (nom, unite_mesure) et valide
activate Vue
Vue -> Controller : POST /ingredients (store)
activate Controller

Controller -> Validator : validate()
activate Validator
Validator --> Controller : Données valides
deactivate Validator

Controller -> BDD : INSERT INTO ingredients (nom, unite_mesure)
activate BDD
BDD --> Controller : Succès (Nouvel ID)
deactivate BDD

Controller --> Vue : redirect()->route('ingredients.index')
deactivate Controller
Vue --> Admin : Affiche la liste avec message "Succès"
deactivate Vue
@enduml