@startuml
skinparam classAttributeIconSize 0
skinparam monochrome false
skinparam shadowing false

title Diagramme de Classes - Livre de Recettes

package "App\\Models" {
    
    class User {
        + int id
        + string name
        + string email
        + string password
        + timestamp created_at
        + timestamp updated_at
    }

    class Recette {
        + int id
        + string titre
        + text description
        + int temps_preparation
        + int portions
        + enum difficulte
        + enum regime_alimentaire
        + boolean est_public
        + int user_id
        + timestamp created_at
        + timestamp updated_at
    }

    class Ingredient {
        + int id
        + string nom
        + string unite_mesure
        + timestamp created_at
        + timestamp updated_at
    }

    class Role <<Spatie>> {
        + int id
        + string name
        + string guard_name
    }

    class "recette_ingredient\n(Table Pivot)" as Pivot {
        + int recette_id
        + int ingredient_id
        + decimal quantite
        + string unite
    }
}

User "1" -- "0..*" Recette : crée >
User "0..*" -- "0..*" Role : possède >
Recette "1" -- "0..*" Pivot : contient >
Ingredient "1" -- "0..*" Pivot : est utilisé dans <

@enduml